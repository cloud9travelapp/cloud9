# --- Auth.js (NextAuth v5) ---
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=

# Google OAuth credentials (Google Cloud Console > APIs & Services > Credentials).
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Supabase ---
# Project URL and the SERVICE ROLE key (Project Settings > API).
# The service-role key is secret — server-only, never expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic (Cloud9 Concierge chat) ---
# API key from https://console.anthropic.com/ (Settings > API keys). Server-only.
ANTHROPIC_API_KEY=

# --- Stays provider (optional; defaults to the seeded mock) ---
# Set STAY_PROVIDER=hotelbeds to serve real hotel availability via Hotelbeds
# APItude. Keys from developer.hotelbeds.com (Hotel API pair). Server-only.
# HOTELBEDS_BASE_URL defaults to the test host (evaluation keys); switch to
# https://api.hotelbeds.com at contract time.
STAY_PROVIDER=
HOTELBEDS_API_KEY=
HOTELBEDS_SECRET=
HOTELBEDS_BASE_URL=
